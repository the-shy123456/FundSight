{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FundSight",
  "version": "0.1.0",
  "identifier": "com.fundsight.desktop",
  "build": {
    "beforeDevCommand": "cd ../../../web && VITE_API_BASE=http://127.0.0.1:18080 npm run dev -- --host 127.0.0.1 --port 5173",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "cd ../../../web && VITE_API_BASE=http://127.0.0.1:18080 npm run build",
    "frontendDist": "../../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "FundSight",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
